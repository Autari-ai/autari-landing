# Copy to .env.local. Never commit .env.local.

# Google Apps Script Web App URL that appends survey rows to your Google Sheet.
# (Same mechanism as the partners site.) See README for the script + deploy steps.
NEXT_PUBLIC_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/XXXXXXXX/exec

